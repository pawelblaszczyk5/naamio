{
	"$schema": "./node_modules/turbo/schema.json",
	"global": { "cacheMaxAge": "7d", "cacheMaxSize": "10GB", "ui": "tui" },
	"futureFlags": {
		"affectedUsingTaskInputs": true,
		"errorsOnlyShowHash": true,
		"filterUsingTasks": true,
		"globalConfiguration": true,
		"longerSignatureKey": true,
		"pruneIncludesGlobalFiles": true,
		"watchUsingTaskInputs": true
	},
	"tasks": {
		"lint": { "dependsOn": ["^build"] },
		"lint:fix": { "dependsOn": ["^build"], "cache": false },
		"build": { "dependsOn": ["^build"], "outputs": ["dist/**"] },
		"typecheck": { "dependsOn": ["^build"] },
		"dev": { "dependsOn": ["^dev"], "cache": false },
		"preview": { "dependsOn": ["build"], "cache": false },
		"codegen": { "dependsOn": [] },
		"test": { "dependsOn": ["build"] },
		"test:dev": { "dependsOn": ["build"], "cache": false, "persistent": true },
		"effect-diagnostics": { "dependsOn": ["^build"] },
		"//#format": { "dependsOn": [] },
		"//#format:fix": { "dependsOn": [], "cache": false },
		"//#sort-package-json": { "inputs": ["**/package.json"], "dependsOn": [] },
		"//#sort-package-json:fix": { "dependsOn": [], "cache": false },
		"//#spellcheck": { "dependsOn": [] }
	}
}
