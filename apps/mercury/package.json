{
	"name": "@naamio/mercury",
	"description": "The API layer of Naamio system",
	"sideEffects": false,
	"type": "module",
	"imports": {
		"#src/*": "./src/*"
	},
	"scripts": {
		"dev": "wait-on tcp:6206 tcp:6207 tcp:6208 && node --env-file=.env --import=tsx --watch ./src/mod.ts",
		"effect-diagnostics": "effect-language-service diagnostics --project tsconfig.json",
		"lint": "eslint",
		"lint:fix": "eslint --fix",
		"preview": "wait-on tcp:6206 tcp:6207 tcp:6208 && node --env-file=.env --import=tsx ./src/mod.ts",
		"typecheck": "tsc --build --noEmit"
	},
	"dependencies": {
		"@effect/platform-node": "catalog:",
		"@effect/platform-node-shared": "catalog:",
		"@effect/sql-pg": "catalog:",
		"@electric-sql/client": "catalog:",
		"@naamio/api": "workspace:",
		"@naamio/hmac": "workspace:",
		"@naamio/id-generator": "workspace:",
		"@naamio/observability": "workspace:",
		"@naamio/schema": "workspace:",
		"@simplewebauthn/server": "^13.3.2",
		"effect": "catalog:",
		"nanoid": "^5.1.16",
		"tsx": "catalog:"
	},
	"devDependencies": {
		"@effect/language-service": "catalog:",
		"@naamio/eslint-config": "workspace:",
		"@naamio/typescript-config": "workspace:",
		"@types/node": "catalog:",
		"eslint": "catalog:",
		"type-fest": "^5.8.0",
		"wait-on": "catalog:"
	}
}
